generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum CaseType {
  court_ordered
  voluntary
  by_agreement
}

enum CaseStatus {
  intake
  order_received
  active
  on_hold
  closed
}

enum ContactType {
  donor
  attorney
  gal
  judge
  court_clerk
  mro
  staff
  evaluator
  other
}

enum ContactPreference {
  email
  phone
  text
}

enum Represents {
  petitioner
  respondent
  child
  neutral
  na
}

enum CaseRole {
  donor
  petitioner_attorney
  respondent_attorney
  gal
  judge
  referring_party
  court_clerk
  evaluator
  other
}

enum SpecimenType {
  urine
  hair
  nail
  blood
  breath
  sweat_patch
  oral_fluid
  unknown_substance
  semen
}

enum Lab {
  usdtl
  crl
  crl_quest
  quest
  expertox
  nms
  medipro
  truetest_inhouse
}

enum TestStatus {
  order_created
  awaiting_payment
  payment_received
  order_released
  awaiting_collection
  specimen_collected
  specimen_held
  sent_to_lab
  at_mro
  mro_released
  results_received
  results_held
  awaiting_payment_for_release
  results_released
  closed
  cancelled
  no_show
}

enum CollectionType {
  observed
  unobserved
  na
}

enum SchedulingType {
  needs_appointment
  scheduled
  random
  walk_in
}

enum AppointmentStatus {
  booked
  completed
  cancelled
  no_show
}

enum DocumentType {
  court_order
  chain_of_custody
  result_report
  invoice
  agreement
  correspondence
  monitoring_order
  cancellation_notice
  other
}

enum ComplianceStatus {
  compliant
  non_compliant
  pending
}

enum ReviewStatus {
  pending_review
  reviewed
  flagged
}

// ─── Sweat patch enums ───────────────────────────────────────────────────
// PharmChek is the patch device manufacturer. CRL (Clinical Reference
// Laboratory) is the testing lab. WA07 and WC82 are CRL's panel codes —
// not PharmChek's. PatchDetails.panel refers to the CRL panel ordered.
enum PatchPanel {
  WA07
  WC82
}

// Patch cancellation kinds live on PatchDetails.cancellationKind. We do NOT
// extend TestStatus — the underlying order still moves through
// awaiting_collection → specimen_collected. The UI uses this field plus
// the two patch dates to render "Patch Applied"/"Patch Removed" labels.
enum PatchCancellationKind {
  cancelled      // Operator-initiated cancellation (donor request, error, etc.)
  lab_cancelled  // Lab rejected the specimen
  expired        // Wore past the 30-day max — set when manually cancelled after the red badge appears
}

// ============================================================
// MODELS
// ============================================================

model Case {
  id                    String        @id @default(cuid())
  caseNumber            String        @unique // TTL-FL-2026-0001
  caseType              CaseType
  caseStatus            CaseStatus    @default(intake)
  courtCaseNumber       String?       // from the court order
  county                String?
  jurisdiction          String?
  judgeName             String?
  hasCourtOrder         Boolean       @default(false)
  isMonitored           Boolean       @default(false) // repeated testing over time w/ random scheduling
  notes                 String?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  createdBy             String?       // staff member name

  // Relations
  donorId               String?
  donor                 Contact?      @relation("CaseDonor", fields: [donorId], references: [id])
  // Referring organization — the firm/practice that sent us this case.
  // Optional because legacy cases predate the Account layer. Use this for
  // "all cases from AHDC" style queries instead of traversing CaseContacts.
  referringAccountId    String?
  referringAccount      Account?      @relation(fields: [referringAccountId], references: [id])
  caseContacts          CaseContact[]
  testOrders            TestOrder[]
  documents             Document[]
  courtOrders           CourtOrder[]
  statusLogs            StatusLog[]
  messages              Message[]
  emailDrafts           EmailDraft[]
  monitoringSchedules   MonitoringSchedule[]
  appointments          Appointment[]

  @@index([caseStatus])
  @@index([caseType])
  @@index([donorId])
  @@index([courtCaseNumber])
  @@index([referringAccountId])
}

model Contact {
  id                String            @id @default(cuid())
  contactType       ContactType
  firstName         String
  lastName          String
  // firmName: legacy free-text. Kept as a read-only display string during
  // the transition to normalized Accounts. Once account backfill is
  // complete, new writes should populate accountId instead. Removing this
  // field is a future cleanup pass.
  firmName          String?
  email             String?
  phone             String?
  preferredContact  ContactPreference @default(email)
  represents        Represents        @default(na)
  barNumber         String?
  notes             String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  // Normalized link to the referring organization (law firm, counseling
  // practice, evaluator office, etc.). Optional because legacy contacts
  // predate the Account layer.
  accountId         String?
  account           Account?          @relation("AccountContacts", fields: [accountId], references: [id])
  primaryForAccounts Account[]        @relation("AccountPrimaryContact")
  donorCases        Case[]            @relation("CaseDonor")
  caseContacts      CaseContact[]
  sentMessages      Message[]         @relation("MessageSender")
  appointments      Appointment[]     @relation("DonorAppointments")

  @@index([contactType])
  @@index([lastName, firstName])
  @@index([email])
  @@index([accountId])
}

// ─────────────────────────────────────────────────────────────────────────
// Account — a referring organization (law firm, counseling practice,
// evaluator office, court, state agency). Cases are referred BY an
// account, individuals (attorneys, counselors, GALs) work AT an account.
// Added to replace free-text Contact.firmName with a queryable entity.
// ─────────────────────────────────────────────────────────────────────────
model Account {
  id                String          @id @default(cuid())
  name              String          // "Associates in Human Development Counseling"
  shortCode         String?         // "AHDC" — optional abbreviation, searchable
  type              AccountType     @default(other)

  // Optional main point of contact at the account. Kept as an explicit
  // FK (not derived from a roleInCase) so a single person can be the
  // standing POC across all cases from this account.
  primaryContactId  String?
  primaryContact    Contact?        @relation("AccountPrimaryContact", fields: [primaryContactId], references: [id])

  // Reachability
  address           String?
  phone             String?
  email             String?
  website           String?
  notes             String?

  // Billing preference — no invoicing logic yet, just the lever so a
  // future build can read this flag and decide per-case vs rolled-up
  // without requiring another migration.
  invoiceGrouping   InvoiceGrouping @default(per_case)

  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  contacts          Contact[]       @relation("AccountContacts")
  cases             Case[]
  defaultRecipients AccountDefaultRecipient[]

  @@index([name])
  @@index([shortCode])
  @@index([active])
}

// AccountDefaultRecipient — people who are automatically added as result/
// invoice recipients on every new case created under this account.
// Stored flat (name + email) rather than FK'd to Contact so the record
// survives contact merges and is self-contained.
model AccountDefaultRecipient {
  id               String   @id @default(cuid())
  accountId        String
  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  email            String?
  phone            String?
  role             CaseRole @default(evaluator)
  receivesResults  Boolean  @default(true)
  receivesStatus   Boolean  @default(false)
  receivesInvoices Boolean  @default(false)
  canOrderTests    Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([accountId])
}

enum AccountType {
  law_firm
  counseling_practice
  evaluator_office
  court
  state_agency
  other
}

enum InvoiceGrouping {
  per_case
  consolidated
}

model CaseContact {
  id               String   @id @default(cuid())
  caseId           String
  contactId        String
  roleInCase       CaseRole
  receivesResults  Boolean  @default(false)
  receivesStatus   Boolean  @default(false)
  receivesInvoices Boolean  @default(false)
  canOrderTests    Boolean  @default(false)
  isPrimaryContact Boolean  @default(false)

  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  contact          Contact  @relation(fields: [contactId], references: [id])

  @@unique([caseId, contactId, roleInCase])
  @@index([caseId])
  @@index([contactId])
}

model TestCatalog {
  id               String       @id @default(cuid())
  category         String       // "Urine", "Hair/Nail", "Blood", etc.
  testName         String
  panelSize        String?      // "5 panel", "10 panel", etc.
  specimenType     SpecimenType
  lab              Lab
  labTestCode      String?      // CRL P705, Quest 35639N, etc.
  clientPrice      Decimal      @db.Decimal(10, 2)
  labCost          Decimal      @db.Decimal(10, 2) // INTERNAL ONLY
  description      String?
  specialHandling  String?      // e.g., "psilocin cold chain requirements"
  isAddOn          Boolean      @default(false)
  active           Boolean      @default(true)

  testOrders           TestOrder[]
  monitoringSchedules  MonitoringSchedule[]

  @@index([category])
  @@index([specimenType])
  @@index([lab])
}

model TestOrder {
  id                   String         @id @default(cuid())
  caseId               String
  testCatalogId        String?
  testDescription      String         // human-readable test name
  specimenType         SpecimenType
  lab                  Lab
  testStatus           TestStatus     @default(order_created)
  collectionType       CollectionType @default(unobserved)
  schedulingType       SchedulingType @default(scheduled)

  // Collection site tracking
  collectionSite       String?        // "Quest PSC - Chicago Loop", "TrueTest Labs - EGV", etc.
  collectionSiteType   String?        // "quest_psc", "truetest", "partner", "mobile"
  orderReleasedDate    DateTime?      // when order was released after payment

  // Payment tracking
  squarePaymentId      String?        // Square payment/invoice ID
  squarePaymentLink    String?        // payment link sent to donor
  paymentMethod        String?        // "square_link", "cash", "check", "credit_card", "attorney_pays"
  paymentDate          DateTime?

  appointmentDate      DateTime?
  collectionDate       DateTime?
  specimenId           String?        // unique specimen identifier
  collectedBy          String?
  specimenHeld         Boolean        @default(false)
  sentToLabDate        DateTime?
  resultsReceivedDate  DateTime?
  resultsReleasedDate  DateTime?

  testvaultOrderId     String?
  labAccessionNumber   String?
  clientPrice          Decimal?       @db.Decimal(10, 2)
  labCost              Decimal?       @db.Decimal(10, 2) // INTERNAL ONLY
  invoiceNumber        String?        // QuickBooks ref

  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  // Relations
  case                 Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  testCatalog          TestCatalog?   @relation(fields: [testCatalogId], references: [id])
  documents            Document[]     @relation("TestOrderDocuments")
  statusLogs           StatusLog[]
  emailDrafts          EmailDraft[]
  randomSelection      RandomSelection?
  labResults           LabResult[]
  patchDetails         PatchDetails?

  @@index([caseId])
  @@index([testStatus])
  @@index([appointmentDate])
}

model Document {
  id              String       @id @default(cuid())
  caseId          String
  documentType    DocumentType
  fileName        String
  filePath        String       // Supabase storage URL
  icloudSyncPath  String?      // local iCloud path
  uploadedBy      String?
  uploadedAt      DateTime     @default(now())
  extractedData   Json?        // parsed content from PDF
  notes           String?

  // Relations
  case            Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  courtOrders     CourtOrder[]
  testOrderId     String?
  testOrder       TestOrder?   @relation("TestOrderDocuments", fields: [testOrderId], references: [id])
  labResults      LabResult[]

  // Monitoring order PDF (Quest ESP) attached to a random selection so the
  // donor can view/download it in the portal on selection day.
  randomSelectionId String?
  randomSelection   RandomSelection? @relation("RandomSelectionDocuments", fields: [randomSelectionId], references: [id], onDelete: SetNull)

  // Reverse side of the two PatchDetails CoC pointers. "Current working"
  // and "executed" CoC membership is authoritative on PatchDetails; these
  // relations exist only so Prisma can traverse them. Archived working
  // copies remain as ordinary Document rows on the TestOrder — recover
  // them by listing chain_of_custody docs for the test order and excluding
  // the two scalar FKs on PatchDetails.
  patchDetailsAsWorkingCopy PatchDetails[] @relation("PatchDetailsWorkingCopy")
  patchDetailsAsExecuted    PatchDetails[] @relation("PatchDetailsExecuted")

  @@index([caseId])
  @@index([documentType])
  @@index([randomSelectionId])
}

// ─────────────────────────────────────────────────────────────────────────
// PatchDetails — 1:1 with a TestOrder when specimenType = sweat_patch.
// Holds the patch-specific workflow state (application + removal dates,
// CRL panel code, CoC lifecycle pointers, cancellation kind) that the
// generic TestOrder can't express.
//
// Mirroring contract: when the executed CoC is uploaded (via
// `executePatchCoc` in src/lib/patchStatus.ts), removalDate is mirrored
// to TestOrder.collectionDate so every query that already reads
// collectionDate keeps working without specimen-type branching.
// ─────────────────────────────────────────────────────────────────────────
model PatchDetails {
  id                    String                 @id @default(cuid())
  testOrderId           String                 @unique
  testOrder             TestOrder              @relation(fields: [testOrderId], references: [id], onDelete: Cascade)

  panel                 PatchPanel

  // Two-date model. applicationDate is captured at patch-on; removalDate
  // at patch-off. Lab's reportedCollectionDate on the result report
  // corresponds to removalDate (specimen left the donor), not
  // applicationDate.
  applicationDate       DateTime?
  removalDate           DateTime?

  // Current working copy and executed CoC documents. When the executed
  // CoC is uploaded, the working copy is *archived* (Document.cocLifecycleStage
  // flipped to `archived`), not deleted — and workingCopyDocumentId is
  // nullified. See replaceWorkingCopy / executePatchCoc in patchStatus.ts.
  workingCopyDocumentId String?
  workingCopyDocument   Document?              @relation("PatchDetailsWorkingCopy", fields: [workingCopyDocumentId], references: [id], onDelete: SetNull)
  executedDocumentId    String?
  executedDocument      Document?              @relation("PatchDetailsExecuted", fields: [executedDocumentId], references: [id], onDelete: SetNull)

  // Cancellation is orthogonal to TestStatus — we keep the order flowing
  // through the standard statuses, and stamp the kind here when cancelled.
  cancellationKind      PatchCancellationKind?
  cancelledAt           DateTime?

  // Replacement-patch capture at cancellation time. When staff cancel a
  // patch, they're asked whether a fresh patch was applied in the same
  // visit; if yes, we stamp these fields AND create a new PatchDetails
  // row (linked to its own new TestOrder on the same case) for the
  // replacement. These two fields are the audit trail on the cancelled
  // patch — `replacementPatchApplied` distinguishes a known "no" from a
  // null "we never asked" (legacy rows). The new replacement patch is
  // discoverable by querying TestOrder.caseId.
  replacementPatchApplied Boolean?
  replacementPatchDate    DateTime?

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([panel])
  @@index([cancellationKind])
  @@index([applicationDate])
  @@index([removalDate])
}

// ─────────────────────────────────────────────────────────────────────────
// LabResult — structured lab-reported data extracted from a result report
// (PDF today, HL7 webhook later). One TestOrder can have multiple rows (e.g.
// an amended report supersedes the prior one). Writing this as a dedicated
// table rather than stuffing JSON into Document.extractedData gives us real
// querying, date cross-checks, and a clean destination for the future USDTL
// webhook parser.
// ─────────────────────────────────────────────────────────────────────────
model LabResult {
  id                      String           @id @default(cuid())
  testOrderId             String
  testOrder               TestOrder        @relation(fields: [testOrderId], references: [id], onDelete: Cascade)

  // Source document — nullable because the future HL7 webhook path may not
  // immediately have a PDF attached (the ED segment extraction may lag).
  documentId              String?
  document                Document?        @relation(fields: [documentId], references: [id], onDelete: SetNull)

  // ── Lab-reported dates (what the report says, not what we recorded) ──
  reportedCollectionDate  DateTime?        // collection date printed on the report
  receivedAtLab           DateTime?        // when the lab received the specimen
  reportDate              DateTime?        // when the lab finalized the report
  mroVerificationDate     DateTime?        // if MRO reviewed, when they signed off

  // When WE received the result (upload time for now, HL7 arrival later).
  receivedByUs            DateTime         @default(now())

  // ── Identifiers from the lab (to cross-check against our records) ──
  labReportNumber         String?          // lab's unique report ID
  labSpecimenId           String?          // what the lab has as the specimen ID
  labName                 String?          // denormalized for query speed

  // ── Overall verdict ──
  overallStatus           LabResultStatus  @default(pending)

  // ── Structured per-analyte data ──
  // JSON shape: Array<{
  //   name: string, cutoff: string?, value: string?,
  //   result: "negative"|"positive"|"inconclusive", notes: string?
  // }>
  analytes                Json?

  // ── Specimen validity (urine-specific; null for hair/blood/etc.) ──
  // { creatinine?: string, ph?: string, status?: "valid"|"dilute"|"adulterated"|"invalid" }
  specimenValidity        Json?

  // ── Cross-check mismatches ──
  // Populated at extraction time by comparing parsed fields against the
  // TestOrder. Array of {
  //   type: "collection_date"|"specimen_id"|"other",
  //   severity: "info"|"warning"|"critical",
  //   ourValue: string, theirValue: string, message: string
  // }
  // Empty array = everything matched. null = cross-check not run yet.
  mismatches              Json?
  mismatchesResolvedAt    DateTime?
  mismatchesResolvedBy    String?          // user id, "auto", or null

  // ── Raw AI text summary (human-readable narrative) ──
  rawSummary              String?          @db.Text

  // ── Summary regenerate history (newest first) ──
  // Each entry: { summary: string, replacedAt: ISO datetime, replacedBy: userId }
  // Appended (prepended) by /api/lab-results/[id]/regenerate-summary so prior
  // narrative versions survive prompt iterations.
  summaryHistory          Json             @default("[]")

  // ── Extraction metadata (useful for debugging + future reprocessing) ──
  source                  String           @default("pdf_upload") // "pdf_upload" | "hl7_webhook" | "manual"
  parserVersion           String?          // prompt/extractor version that wrote this row
  extractedAt             DateTime         @default(now())

  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([testOrderId])
  @@index([overallStatus])
  @@index([receivedByUs])
  @@index([labReportNumber])
}

enum LabResultStatus {
  pending       // extraction in progress or failed
  negative      // all analytes below cutoff
  positive      // one or more analytes above cutoff (and not downgraded by MRO)
  dilute        // specimen flagged dilute
  adulterated   // specimen flagged adulterated
  invalid       // specimen validity failed outright
  mixed         // partial — e.g. some analytes positive and MRO verified one negative
  mro_pending   // awaiting MRO review
  mro_verified_negative // MRO downgraded to negative
  unknown       // parser couldn't determine status
}

model CourtOrder {
  id                  String           @id @default(cuid())
  caseId              String
  documentId          String
  orderDate           DateTime?
  judgeName           String?
  courtCaseNumber     String?
  county              String?
  testsOrdered        Json?            // array of test types/frequencies
  testingDuration     String?          // "6 months", "until further order"
  startDate           DateTime?
  endDate             DateTime?
  frequency           String?          // "random 2x/month", "weekly", etc.
  whoPays             String?
  resultDistribution  Json?            // who gets results per the order
  specialInstructions String?
  complianceStatus    ComplianceStatus @default(pending)
  parsedByAi          Boolean          @default(false)
  reviewStatus        ReviewStatus     @default(pending_review)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // Relations
  case                Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  document            Document         @relation(fields: [documentId], references: [id])

  @@index([caseId])
}

model StatusLog {
  id                     String    @id @default(cuid())
  caseId                 String?
  testOrderId            String?
  oldStatus              String
  newStatus              String
  changedBy              String
  changedAt              DateTime  @default(now())
  note                   String?
  notificationSent       Boolean   @default(false)
  notificationRecipients Json?

  // Relations
  case                   Case?     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  testOrder              TestOrder? @relation(fields: [testOrderId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([testOrderId])
  @@index([changedAt])
}

model Message {
  id             String   @id @default(cuid())
  caseId         String
  fromContactId  String?
  toContacts     Json     // array of contact IDs
  subject        String?
  body           String
  sentAt         DateTime @default(now())
  readBy         Json?    // tracking who read it

  // Relations
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromContact    Contact? @relation("MessageSender", fields: [fromContactId], references: [id])

  @@index([caseId])
  @@index([sentAt])
}

model EmailDraft {
  id           String    @id @default(cuid())
  caseId       String
  case         Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  testOrderId  String?
  testOrder    TestOrder? @relation(fields: [testOrderId], references: [id])

  draftType    String    // "results" | "results_mro"
  recipients   Json      // string[] of email addresses
  subject      String
  body         String    // plain-text summary (editable before send)

  status       String    @default("pending") // "pending" | "sent"
  createdBy    String    @default("admin")
  createdAt    DateTime  @default(now())
  sentAt       DateTime?

  @@index([status])
  @@index([caseId])
}

// ============================================================
// KIOSK INTAKE DRAFTS
// ============================================================

model IntakeDraft {
  id                    String   @id @default(cuid())
  status                String   @default("pending_review") // pending_review | approved | rejected
  firstName             String
  lastName              String
  phone                 String?
  email                 String?
  existingDonorId       String?
  caseType              String   // court_ordered | voluntary | by_agreement
  courtCaseNumber       String?
  county                String?
  judgeName             String?
  hasCourtOrder         Boolean  @default(false)
  courtOrderPath        String?  // Supabase storage path
  attorneys             Json?    // [{ name, firm, email, phone, role, contactId? }]
  galInfo               Json?    // { name, firm, email, phone, contactId? }
  evaluators            Json?    // [{ name, firm, email, phone, contactId? }] — court-ordered doctors
  orderedBy             String?  // attorney | judge | self | other
  paymentResponsibility String?  // self | attorney | other
  testTypes             Json?    // ["urine", "hair", "blood_peth", "sweat_patch"]
  additionalRecipients  Json?    // [{ name?: string, email: string }] for Personal visits
  notes                 String?
  communicationConsent  Boolean  @default(false)
  changes               Json?    // structured diff when returning client updated info; null = nothing changed
  createdAt             DateTime @default(now())
  reviewedAt            DateTime?
  reviewedBy            String?
  caseId                String?  // set when approved → case created

  @@index([status])
  @@index([createdAt])
}

// ============================================================
// APPOINTMENTS — case tracker owns availability (v1)
// ============================================================

model Appointment {
  id         String            @id @default(cuid())
  startTime  DateTime
  endTime    DateTime
  status     AppointmentStatus @default(booked)
  caseId     String?
  case       Case?             @relation(fields: [caseId], references: [id], onDelete: SetNull)
  donorId    String?
  donor      Contact?          @relation("DonorAppointments", fields: [donorId], references: [id], onDelete: SetNull)
  notes          String?
  createdBy      String?           // "phone-intake" | "kiosk" | staff name
  googleEventId  String?           // Google Calendar event ID after sync
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([startTime])
  @@index([caseId])
  @@index([donorId])
  @@index([status])
}

// ============================================================
// RANDOM MONITORING SCHEDULER
// ============================================================

model MonitoringSchedule {
  id                   String          @id @default(cuid())
  caseId               String
  case                 Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Test config (locked at creation)
  testCatalogId        String
  testCatalog          TestCatalog     @relation(fields: [testCatalogId], references: [id])
  collectionType       CollectionType  @default(unobserved)

  // Donor check-in
  checkInPin           String          @unique  // 6- or 8-digit PIN donor enters at /portal

  // PIN brute-force protection — set when this schedule hits the OTP-fail
  // threshold; login is rejected with 423 until pinLockedUntil passes.
  pinLockedUntil       DateTime?
  pinFailCount         Int             @default(0)

  // Stamped by /send-instructions after successful compliance-email send.
  // UI gates the Instructions / Resend-PIN buttons on this — before it's set,
  // Resend-PIN is disabled (no point until the donor has the full email);
  // after, Instructions is disabled (prevents duplicate compliance emails).
  instructionsSentAt   DateTime?

  // Pattern
  patternType          String          // "range_count" | "per_month" | "per_week"
  targetCount          Int             // 12 (total) or 2 (per period)
  minSpacingDays       Int?            // optional spacing constraint
  allowedDays          Json?           // array of day numbers [0-6], 0=Sun, 1=Mon, etc. Default: [1,2,3,4,5]

  // Date range
  startDate            DateTime
  endDate              DateTime?       // null = ongoing

  // Miss handling
  autoRescheduleOnMiss Boolean         @default(true)
  autoRescheduleDays   Int             @default(1)

  // State
  active               Boolean         @default(true)
  lastGeneratedThrough DateTime?       // how far ahead selections have been generated
  createdAt            DateTime        @default(now())
  createdBy            String?

  selections           RandomSelection[]
  checkIns             CheckIn[]
  pushSubscriptions    PushSubscription[]
  trustedDevices       TrustedDevice[]
  portalOtps           PortalOtp[]

  @@index([caseId])
  @@index([active])
}

// ─────────────────────────────────────────────────────────────────────────
// TrustedDevice — a browser/phone that has cleared PIN + SMS OTP once. The
// random `deviceId` is written to an HTTP-only cookie and presented on
// future logins to skip the OTP challenge. Staff can revoke a device from
// the schedule detail if a donor reports theft.
// ─────────────────────────────────────────────────────────────────────────
model TrustedDevice {
  id         String             @id @default(cuid())
  scheduleId String
  schedule   MonitoringSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  deviceId   String             @unique  // random 32-byte id, written to cookie
  userAgent  String?
  ipAddress  String?

  createdAt  DateTime           @default(now())
  lastSeenAt DateTime           @default(now())
  revokedAt  DateTime?

  @@index([scheduleId])
}

// ─────────────────────────────────────────────────────────────────────────
// PortalOtp — pending one-time SMS code issued when a donor logs in from an
// untrusted device. Code itself is SHA256-hashed; we only ever compare
// hashes. TTL is 5 minutes and max 5 verify attempts per row.
// ─────────────────────────────────────────────────────────────────────────
model PortalOtp {
  id          String             @id @default(cuid())
  scheduleId  String
  schedule    MonitoringSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  phone       String             // E.164, for per-phone request rate limiting
  codeHash    String             // SHA256(code)
  expiresAt   DateTime
  attempts    Int                @default(0)
  consumedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([phone, expiresAt])
  @@index([scheduleId, expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────
// PortalLoginAttempt — every donor-portal auth event (login, OTP request,
// OTP verify, session check). Success or failure. Drives the per-IP and
// per-schedule anomaly alerts and gives us a queryable audit trail for
// the donor flow (AuditLog is keyed on User, which portal visitors aren't).
// ─────────────────────────────────────────────────────────────────────────
model PortalLoginAttempt {
  id          String   @id @default(cuid())
  scheduleId  String?  // null when PIN didn't match a known schedule
  action      String   // "login" | "otp_request" | "otp_verify" | "logout"
  success     Boolean
  reason      String?  // "invalid_pin" | "locked" | "otp_required" | "bad_otp" | "otp_expired" | "ok"
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([scheduleId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([createdAt])
}

model RandomSelection {
  id                   String          @id @default(cuid())
  scheduleId           String
  schedule             MonitoringSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  selectedDate         DateTime        // date picked (UTC midnight)
  status               String          @default("pending") // pending | notified | completed | refused | cancelled

  notifiedAt           DateTime?
  acknowledgedAt       DateTime?       // donor confirmed receipt via portal/PIN — silences escalating notifications
  completedAt          DateTime?

  testOrderId          String?         @unique
  testOrder            TestOrder?      @relation(fields: [testOrderId], references: [id])

  // Replacement chain
  replacesSelectionId  String?         @unique
  replacesSelection    RandomSelection? @relation("Replacement", fields: [replacesSelectionId], references: [id])
  replacementSelection RandomSelection? @relation("Replacement")

  // Quest ESP order PDF(s) attached by staff for donor viewing
  documents            Document[]      @relation("RandomSelectionDocuments")
  notificationJobs     NotificationJob[]

  createdAt            DateTime        @default(now())

  @@index([scheduleId, selectedDate])
  @@index([selectedDate, status])
}

// ─────────────────────────────────────────────────────────────────────────
// NotificationJob — one row per scheduled push/SMS/email/voice attempt on
// a donor's selection day. Seeded at 6am local by /api/cron/seed-notifications
// and dispatched by /api/cron/run-notifications every 5 min. Any job whose
// parent selection has `acknowledgedAt` is skipped at dispatch time.
// ─────────────────────────────────────────────────────────────────────────
model NotificationJob {
  id              String           @id @default(cuid())
  selectionId     String
  selection       RandomSelection  @relation(fields: [selectionId], references: [id], onDelete: Cascade)

  channel         String           // push | sms | email | voice
  sendAt          DateTime
  status          String           @default("pending") // pending | sent | skipped | failed
  sentAt          DateTime?
  errorMessage    String?

  createdAt       DateTime         @default(now())

  @@index([status, sendAt])
  @@index([selectionId])
}

// ─────────────────────────────────────────────────────────────────────────
// PushSubscription — a donor's Web Push endpoint stored per schedule so
// escalating notifications on selection days can reach them even when the
// portal tab is closed. VAPID keys are managed in env.
// ─────────────────────────────────────────────────────────────────────────
model PushSubscription {
  id              String             @id @default(cuid())
  scheduleId      String
  schedule        MonitoringSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  endpoint        String             @unique
  p256dh          String
  auth            String
  userAgent       String?

  createdAt       DateTime           @default(now())
  lastUsedAt      DateTime?

  @@index([scheduleId])
}

model CheckIn {
  id              String              @id @default(cuid())
  scheduleId      String
  schedule        MonitoringSchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  checkedInAt     DateTime            @default(now())
  wasSelected     Boolean             // true if a selection existed for today
  selectionId     String?
  ipAddress       String?
  userAgent       String?

  @@index([scheduleId, checkedInAt])
}

// ============================================================
// AUTH + AUDIT
// ============================================================

model User {
  id          String     @id // Supabase Auth UUID
  email       String     @unique
  name        String
  role        String     @default("staff") // "admin" | "staff"
  createdAt   DateTime   @default(now())
  lastLoginAt DateTime?
  auditLogs   AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // login, view_case, create_case, delete_case, upload_document, etc.
  resource   String?  // case, test_order, contact, document, appointment
  resourceId String?  // specific record ID
  metadata   Json?    // IP, user agent, old/new values
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resourceId])
  @@index([createdAt])
}
