generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum CaseType {
  court_ordered
  voluntary
  by_agreement
}

enum CaseStatus {
  intake
  order_received
  active
  on_hold
  closed
}

enum ContactType {
  donor
  attorney
  gal
  judge
  court_clerk
  mro
  staff
  evaluator
  other
}

enum ContactPreference {
  email
  phone
  text
}

enum Represents {
  petitioner
  respondent
  child
  neutral
  na
}

enum CaseRole {
  donor
  petitioner_attorney
  respondent_attorney
  gal
  judge
  referring_party
  court_clerk
  evaluator
  other
}

enum SpecimenType {
  urine
  hair
  nail
  blood
  breath
  sweat_patch
  oral_fluid
  unknown_substance
  semen
}

enum Lab {
  usdtl
  crl_quest
  quest
  expertox
  nms
  medipro
  truetest_inhouse
}

enum TestStatus {
  order_created
  awaiting_payment
  payment_received
  order_released
  awaiting_collection
  specimen_collected
  specimen_held
  sent_to_lab
  at_mro
  mro_released
  results_received
  results_held
  awaiting_payment_for_release
  results_released
  closed
  cancelled
  no_show
}

enum CollectionType {
  observed
  unobserved
  na
}

enum SchedulingType {
  needs_appointment
  scheduled
  random
  walk_in
}

enum AppointmentStatus {
  booked
  completed
  cancelled
  no_show
}

enum DocumentType {
  court_order
  chain_of_custody
  result_report
  invoice
  agreement
  correspondence
  other
}

enum ComplianceStatus {
  compliant
  non_compliant
  pending
}

enum ReviewStatus {
  pending_review
  reviewed
  flagged
}

// ============================================================
// MODELS
// ============================================================

model Case {
  id                    String        @id @default(cuid())
  caseNumber            String        @unique // TTL-FL-2026-0001
  caseType              CaseType
  caseStatus            CaseStatus    @default(intake)
  courtCaseNumber       String?       // from the court order
  county                String?
  jurisdiction          String?
  judgeName             String?
  hasCourtOrder         Boolean       @default(false)
  isMonitored           Boolean       @default(false) // repeated testing over time w/ random scheduling
  notes                 String?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  createdBy             String?       // staff member name

  // Relations
  donorId               String?
  donor                 Contact?      @relation("CaseDonor", fields: [donorId], references: [id])
  // Referring organization — the firm/practice that sent us this case.
  // Optional because legacy cases predate the Account layer. Use this for
  // "all cases from AHDC" style queries instead of traversing CaseContacts.
  referringAccountId    String?
  referringAccount      Account?      @relation(fields: [referringAccountId], references: [id])
  caseContacts          CaseContact[]
  testOrders            TestOrder[]
  documents             Document[]
  courtOrders           CourtOrder[]
  statusLogs            StatusLog[]
  messages              Message[]
  emailDrafts           EmailDraft[]
  monitoringSchedules   MonitoringSchedule[]
  appointments          Appointment[]
  callLogs              CallLog[]

  @@index([caseStatus])
  @@index([caseType])
  @@index([donorId])
  @@index([courtCaseNumber])
  @@index([referringAccountId])
}

model Contact {
  id                String            @id @default(cuid())
  contactType       ContactType
  firstName         String
  lastName          String
  // firmName: legacy free-text. Kept as a read-only display string during
  // the transition to normalized Accounts. Once account backfill is
  // complete, new writes should populate accountId instead. Removing this
  // field is a future cleanup pass.
  firmName          String?
  email             String?
  phone             String?
  preferredContact  ContactPreference @default(email)
  represents        Represents        @default(na)
  barNumber         String?
  notes             String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  // Normalized link to the referring organization (law firm, counseling
  // practice, evaluator office, etc.). Optional because legacy contacts
  // predate the Account layer.
  accountId         String?
  account           Account?          @relation("AccountContacts", fields: [accountId], references: [id])
  primaryForAccounts Account[]        @relation("AccountPrimaryContact")
  donorCases        Case[]            @relation("CaseDonor")
  caseContacts      CaseContact[]
  sentMessages      Message[]         @relation("MessageSender")
  appointments      Appointment[]     @relation("DonorAppointments")

  @@index([contactType])
  @@index([lastName, firstName])
  @@index([email])
  @@index([accountId])
}

// ─────────────────────────────────────────────────────────────────────────
// Account — a referring organization (law firm, counseling practice,
// evaluator office, court, state agency). Cases are referred BY an
// account, individuals (attorneys, counselors, GALs) work AT an account.
// Added to replace free-text Contact.firmName with a queryable entity.
// ─────────────────────────────────────────────────────────────────────────
model Account {
  id                String          @id @default(cuid())
  name              String          // "Associates in Human Development Counseling"
  shortCode         String?         // "AHDC" — optional abbreviation, searchable
  type              AccountType     @default(other)

  // Optional main point of contact at the account. Kept as an explicit
  // FK (not derived from a roleInCase) so a single person can be the
  // standing POC across all cases from this account.
  primaryContactId  String?
  primaryContact    Contact?        @relation("AccountPrimaryContact", fields: [primaryContactId], references: [id])

  // Reachability
  address           String?
  phone             String?
  email             String?
  website           String?
  notes             String?

  // Billing preference — no invoicing logic yet, just the lever so a
  // future build can read this flag and decide per-case vs rolled-up
  // without requiring another migration.
  invoiceGrouping   InvoiceGrouping @default(per_case)

  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  contacts          Contact[]       @relation("AccountContacts")
  cases             Case[]
  defaultRecipients AccountDefaultRecipient[]

  @@index([name])
  @@index([shortCode])
  @@index([active])
}

// AccountDefaultRecipient — people who are automatically added as result/
// invoice recipients on every new case created under this account.
// Stored flat (name + email) rather than FK'd to Contact so the record
// survives contact merges and is self-contained.
model AccountDefaultRecipient {
  id               String   @id @default(cuid())
  accountId        String
  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  email            String?
  phone            String?
  role             CaseRole @default(evaluator)
  receivesResults  Boolean  @default(true)
  receivesStatus   Boolean  @default(false)
  receivesInvoices Boolean  @default(false)
  canOrderTests    Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([accountId])
}

enum AccountType {
  law_firm
  counseling_practice
  evaluator_office
  court
  state_agency
  other
}

enum InvoiceGrouping {
  per_case
  consolidated
}

model CaseContact {
  id               String   @id @default(cuid())
  caseId           String
  contactId        String
  roleInCase       CaseRole
  receivesResults  Boolean  @default(false)
  receivesStatus   Boolean  @default(false)
  receivesInvoices Boolean  @default(false)
  canOrderTests    Boolean  @default(false)
  isPrimaryContact Boolean  @default(false)

  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  contact          Contact  @relation(fields: [contactId], references: [id])

  @@unique([caseId, contactId, roleInCase])
  @@index([caseId])
  @@index([contactId])
}

model TestCatalog {
  id               String       @id @default(cuid())
  category         String       // "Urine", "Hair/Nail", "Blood", etc.
  testName         String
  panelSize        String?      // "5 panel", "10 panel", etc.
  specimenType     SpecimenType
  lab              Lab
  labTestCode      String?      // CRL P705, Quest 35639N, etc.
  clientPrice      Decimal      @db.Decimal(10, 2)
  labCost          Decimal      @db.Decimal(10, 2) // INTERNAL ONLY
  description      String?
  specialHandling  String?      // e.g., "psilocin cold chain requirements"
  isAddOn          Boolean      @default(false)
  active           Boolean      @default(true)

  testOrders           TestOrder[]
  monitoringSchedules  MonitoringSchedule[]

  @@index([category])
  @@index([specimenType])
  @@index([lab])
}

model TestOrder {
  id                   String         @id @default(cuid())
  caseId               String
  testCatalogId        String?
  testDescription      String         // human-readable test name
  specimenType         SpecimenType
  lab                  Lab
  testStatus           TestStatus     @default(order_created)
  collectionType       CollectionType @default(unobserved)
  schedulingType       SchedulingType @default(scheduled)

  // Collection site tracking
  collectionSite       String?        // "Quest PSC - Chicago Loop", "TrueTest Labs - EGV", etc.
  collectionSiteType   String?        // "quest_psc", "truetest", "partner", "mobile"
  orderReleasedDate    DateTime?      // when order was released after payment

  // Payment tracking
  squarePaymentId      String?        // Square payment/invoice ID
  squarePaymentLink    String?        // payment link sent to donor
  paymentMethod        String?        // "square_link", "cash", "check", "credit_card", "attorney_pays"
  paymentDate          DateTime?

  appointmentDate      DateTime?
  collectionDate       DateTime?
  specimenId           String?        // unique specimen identifier
  collectedBy          String?
  specimenHeld         Boolean        @default(false)
  sentToLabDate        DateTime?
  resultsReceivedDate  DateTime?
  resultsReleasedDate  DateTime?

  testvaultOrderId     String?
  labAccessionNumber   String?
  clientPrice          Decimal?       @db.Decimal(10, 2)
  labCost              Decimal?       @db.Decimal(10, 2) // INTERNAL ONLY
  invoiceNumber        String?        // QuickBooks ref

  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  // Relations
  case                 Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  testCatalog          TestCatalog?   @relation(fields: [testCatalogId], references: [id])
  documents            Document[]     @relation("TestOrderDocuments")
  statusLogs           StatusLog[]
  emailDrafts          EmailDraft[]
  randomSelection      RandomSelection?
  labResults           LabResult[]

  @@index([caseId])
  @@index([testStatus])
  @@index([appointmentDate])
}

model Document {
  id              String       @id @default(cuid())
  caseId          String
  documentType    DocumentType
  fileName        String
  filePath        String       // Supabase storage URL
  icloudSyncPath  String?      // local iCloud path
  uploadedBy      String?
  uploadedAt      DateTime     @default(now())
  extractedData   Json?        // parsed content from PDF
  notes           String?

  // Relations
  case            Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  courtOrders     CourtOrder[]
  testOrderId     String?
  testOrder       TestOrder?   @relation("TestOrderDocuments", fields: [testOrderId], references: [id])
  labResults      LabResult[]

  @@index([caseId])
  @@index([documentType])
}

// ─────────────────────────────────────────────────────────────────────────
// LabResult — structured lab-reported data extracted from a result report
// (PDF today, HL7 webhook later). One TestOrder can have multiple rows (e.g.
// an amended report supersedes the prior one). Writing this as a dedicated
// table rather than stuffing JSON into Document.extractedData gives us real
// querying, date cross-checks, and a clean destination for the future USDTL
// webhook parser.
// ─────────────────────────────────────────────────────────────────────────
model LabResult {
  id                      String           @id @default(cuid())
  testOrderId             String
  testOrder               TestOrder        @relation(fields: [testOrderId], references: [id], onDelete: Cascade)

  // Source document — nullable because the future HL7 webhook path may not
  // immediately have a PDF attached (the ED segment extraction may lag).
  documentId              String?
  document                Document?        @relation(fields: [documentId], references: [id], onDelete: SetNull)

  // ── Lab-reported dates (what the report says, not what we recorded) ──
  reportedCollectionDate  DateTime?        // collection date printed on the report
  receivedAtLab           DateTime?        // when the lab received the specimen
  reportDate              DateTime?        // when the lab finalized the report
  mroVerificationDate     DateTime?        // if MRO reviewed, when they signed off

  // When WE received the result (upload time for now, HL7 arrival later).
  receivedByUs            DateTime         @default(now())

  // ── Identifiers from the lab (to cross-check against our records) ──
  labReportNumber         String?          // lab's unique report ID
  labSpecimenId           String?          // what the lab has as the specimen ID
  labName                 String?          // denormalized for query speed

  // ── Overall verdict ──
  overallStatus           LabResultStatus  @default(pending)

  // ── Structured per-analyte data ──
  // JSON shape: Array<{
  //   name: string, cutoff: string?, value: string?,
  //   result: "negative"|"positive"|"inconclusive", notes: string?
  // }>
  analytes                Json?

  // ── Specimen validity (urine-specific; null for hair/blood/etc.) ──
  // { creatinine?: string, ph?: string, status?: "valid"|"dilute"|"adulterated"|"invalid" }
  specimenValidity        Json?

  // ── Cross-check mismatches ──
  // Populated at extraction time by comparing parsed fields against the
  // TestOrder. Array of {
  //   type: "collection_date"|"specimen_id"|"other",
  //   severity: "info"|"warning"|"critical",
  //   ourValue: string, theirValue: string, message: string
  // }
  // Empty array = everything matched. null = cross-check not run yet.
  mismatches              Json?
  mismatchesResolvedAt    DateTime?
  mismatchesResolvedBy    String?          // user id, "auto", or null

  // ── Raw AI text summary (human-readable narrative) ──
  rawSummary              String?          @db.Text

  // ── Extraction metadata (useful for debugging + future reprocessing) ──
  source                  String           @default("pdf_upload") // "pdf_upload" | "hl7_webhook" | "manual"
  parserVersion           String?          // prompt/extractor version that wrote this row
  extractedAt             DateTime         @default(now())

  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([testOrderId])
  @@index([overallStatus])
  @@index([receivedByUs])
  @@index([labReportNumber])
}

enum LabResultStatus {
  pending       // extraction in progress or failed
  negative      // all analytes below cutoff
  positive      // one or more analytes above cutoff (and not downgraded by MRO)
  dilute        // specimen flagged dilute
  adulterated   // specimen flagged adulterated
  invalid       // specimen validity failed outright
  mixed         // partial — e.g. some analytes positive and MRO verified one negative
  mro_pending   // awaiting MRO review
  mro_verified_negative // MRO downgraded to negative
  unknown       // parser couldn't determine status
}

model CourtOrder {
  id                  String           @id @default(cuid())
  caseId              String
  documentId          String
  orderDate           DateTime?
  judgeName           String?
  courtCaseNumber     String?
  county              String?
  testsOrdered        Json?            // array of test types/frequencies
  testingDuration     String?          // "6 months", "until further order"
  startDate           DateTime?
  endDate             DateTime?
  frequency           String?          // "random 2x/month", "weekly", etc.
  whoPays             String?
  resultDistribution  Json?            // who gets results per the order
  specialInstructions String?
  complianceStatus    ComplianceStatus @default(pending)
  parsedByAi          Boolean          @default(false)
  reviewStatus        ReviewStatus     @default(pending_review)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // Relations
  case                Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  document            Document         @relation(fields: [documentId], references: [id])

  @@index([caseId])
}

model StatusLog {
  id                     String    @id @default(cuid())
  caseId                 String?
  testOrderId            String?
  oldStatus              String
  newStatus              String
  changedBy              String
  changedAt              DateTime  @default(now())
  note                   String?
  notificationSent       Boolean   @default(false)
  notificationRecipients Json?

  // Relations
  case                   Case?     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  testOrder              TestOrder? @relation(fields: [testOrderId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([testOrderId])
  @@index([changedAt])
}

model Message {
  id             String   @id @default(cuid())
  caseId         String
  fromContactId  String?
  toContacts     Json     // array of contact IDs
  subject        String?
  body           String
  sentAt         DateTime @default(now())
  readBy         Json?    // tracking who read it

  // Relations
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromContact    Contact? @relation("MessageSender", fields: [fromContactId], references: [id])

  @@index([caseId])
  @@index([sentAt])
}

model EmailDraft {
  id           String    @id @default(cuid())
  caseId       String
  case         Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  testOrderId  String?
  testOrder    TestOrder? @relation(fields: [testOrderId], references: [id])

  draftType    String    // "results" | "results_mro"
  recipients   Json      // string[] of email addresses
  subject      String
  body         String    // plain-text summary (editable before send)

  status       String    @default("pending") // "pending" | "sent"
  createdBy    String    @default("admin")
  createdAt    DateTime  @default(now())
  sentAt       DateTime?

  @@index([status])
  @@index([caseId])
}

// ============================================================
// KIOSK INTAKE DRAFTS
// ============================================================

model IntakeDraft {
  id                    String   @id @default(cuid())
  status                String   @default("pending_review") // pending_review | approved | rejected
  firstName             String
  lastName              String
  phone                 String?
  email                 String?
  existingDonorId       String?
  caseType              String   // court_ordered | voluntary | by_agreement
  courtCaseNumber       String?
  county                String?
  judgeName             String?
  hasCourtOrder         Boolean  @default(false)
  courtOrderPath        String?  // Supabase storage path
  attorneys             Json?    // [{ name, firm, email, phone, role, contactId? }]
  galInfo               Json?    // { name, firm, email, phone, contactId? }
  evaluators            Json?    // [{ name, firm, email, phone, contactId? }] — court-ordered doctors
  orderedBy             String?  // attorney | judge | self | other
  paymentResponsibility String?  // self | attorney | other
  testTypes             Json?    // ["urine", "hair", "blood_peth", "sweat_patch"]
  additionalRecipients  Json?    // [{ name?: string, email: string }] for Personal visits
  notes                 String?
  communicationConsent  Boolean  @default(false)
  changes               Json?    // structured diff when returning client updated info; null = nothing changed
  createdAt             DateTime @default(now())
  reviewedAt            DateTime?
  reviewedBy            String?
  caseId                String?  // set when approved → case created

  @@index([status])
  @@index([createdAt])
}

// ============================================================
// APPOINTMENTS — case tracker owns availability (v1)
// ============================================================

model Appointment {
  id         String            @id @default(cuid())
  startTime  DateTime
  endTime    DateTime
  status     AppointmentStatus @default(booked)
  caseId     String?
  case       Case?             @relation(fields: [caseId], references: [id], onDelete: SetNull)
  donorId    String?
  donor      Contact?          @relation("DonorAppointments", fields: [donorId], references: [id], onDelete: SetNull)
  notes          String?
  createdBy      String?           // "phone-intake" | "kiosk" | staff name
  googleEventId  String?           // Google Calendar event ID after sync
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([startTime])
  @@index([caseId])
  @@index([donorId])
  @@index([status])
}

// ============================================================
// RANDOM MONITORING SCHEDULER
// ============================================================

model MonitoringSchedule {
  id                   String          @id @default(cuid())
  caseId               String
  case                 Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Test config (locked at creation)
  testCatalogId        String
  testCatalog          TestCatalog     @relation(fields: [testCatalogId], references: [id])
  collectionType       CollectionType  @default(unobserved)

  // Donor check-in
  checkInPin           String          @unique  // 6-digit PIN donor enters at /checkin

  // Pattern
  patternType          String          // "range_count" | "per_month" | "per_week"
  targetCount          Int             // 12 (total) or 2 (per period)
  minSpacingDays       Int?            // optional spacing constraint
  allowedDays          Json?           // array of day numbers [0-6], 0=Sun, 1=Mon, etc. Default: [1,2,3,4,5]

  // Date range
  startDate            DateTime
  endDate              DateTime?       // null = ongoing

  // Miss handling
  autoRescheduleOnMiss Boolean         @default(true)
  autoRescheduleDays   Int             @default(1)

  // State
  active               Boolean         @default(true)
  lastGeneratedThrough DateTime?       // how far ahead selections have been generated
  createdAt            DateTime        @default(now())
  createdBy            String?

  selections           RandomSelection[]
  checkIns             CheckIn[]

  @@index([caseId])
  @@index([active])
}

model RandomSelection {
  id                   String          @id @default(cuid())
  scheduleId           String
  schedule             MonitoringSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  selectedDate         DateTime        // date picked (UTC midnight)
  status               String          @default("pending") // pending | notified | completed | refused | cancelled

  notifiedAt           DateTime?
  completedAt          DateTime?

  testOrderId          String?         @unique
  testOrder            TestOrder?      @relation(fields: [testOrderId], references: [id])

  // Replacement chain
  replacesSelectionId  String?         @unique
  replacesSelection    RandomSelection? @relation("Replacement", fields: [replacesSelectionId], references: [id])
  replacementSelection RandomSelection? @relation("Replacement")

  createdAt            DateTime        @default(now())

  @@index([scheduleId, selectedDate])
  @@index([selectedDate, status])
}

model CheckIn {
  id              String              @id @default(cuid())
  scheduleId      String
  schedule        MonitoringSchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  checkedInAt     DateTime            @default(now())
  wasSelected     Boolean             // true if a selection existed for today
  selectionId     String?
  ipAddress       String?
  userAgent       String?

  @@index([scheduleId, checkedInAt])
}

// ============================================================
// AUTH + AUDIT
// ============================================================

model User {
  id          String     @id // Supabase Auth UUID
  email       String     @unique
  name        String
  role        String     @default("staff") // "admin" | "staff"
  createdAt   DateTime   @default(now())
  lastLoginAt DateTime?
  auditLogs   AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // login, view_case, create_case, delete_case, upload_document, etc.
  resource   String?  // case, test_order, contact, document, appointment
  resourceId String?  // specific record ID
  metadata   Json?    // IP, user agent, old/new values
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resourceId])
  @@index([createdAt])
}

// ============================================================
// AI PHONE AGENT
// ============================================================
// CallLog is written by the voice agent at /api/voice/*. One row per
// inbound call Twilio forwards to us (post Phone.com no-answer). The
// transcript is an append-only array of {role, text, at} turns;
// summary + outcome are filled by a post-call Claude pass in the status
// webhook. matchedCaseId is set when the agent identifies the caller
// against an existing Case; nullable because most new-client calls
// won't match.

model CallLog {
  id              String    @id @default(cuid())
  // Unique ID from whichever voice provider handled the call. For
  // Twilio-native calls this is the CallSid; for Vapi-hosted calls
  // this is the Vapi call.id. We don't store both because every call
  // belongs to exactly one logical stream.
  externalCallId  String    @unique
  provider        String    @default("vapi") // vapi | twilio
  assistantId     String?   // Vapi assistant ID, for audit / multi-assistant setups
  fromNumber      String
  toNumber        String?

  // Caller identification (agent-populated as the call progresses)
  callerName      String?
  callbackNumber  String?   // what the caller asked us to call back, if different from fromNumber
  matchedCaseId   String?
  matchedCase     Case?     @relation(fields: [matchedCaseId], references: [id])

  // Classification
  segment         String?   // family_law | dot | non_dot | dna | unknown
  intent          String?   // new_client | status_inquiry | appointment | vendor | legal | partnership | spam | other
  urgency         String?   // low | normal | high
  language        String?   // en | es | other
  outcome         String?   // message_taken | booked_appointment | status_given | transferred | hung_up | failed

  // Content
  transcript      Json?     // array of { role: "agent" | "caller" | "system", text: string, at: ISO }
  summary         String?   // 1-3 sentence Claude summary written post-call
  aiDisclosed     Boolean   @default(false)

  // Outbound side-effects
  recapSmsSentAt  DateTime?
  recapSmsBody    String?
  notifiedStaffAt DateTime?

  // Twilio call metadata
  durationSec     Int?
  recordingUrl    String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?

  @@index([startedAt])
  @@index([matchedCaseId])
  @@index([outcome])
  @@index([intent])
}
