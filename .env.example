# Supabase Connection
# Get these from your Supabase project: Settings > Database
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase Auth & Storage
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Claude AI (for scanned PDF parsing)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Twilio SMS (for phone-intake appointment confirmations)
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Google Calendar sync (shared TrueTest calendar)
# One-time setup:
#   1. console.cloud.google.com → create project → enable Calendar API
#   2. IAM → Service Accounts → create "truetest-case-tracker" → download JSON key
#   3. Share target calendar with service account email, "Make changes to events"
#   4. Copy Calendar ID from calendar settings
# Paste the whole service account JSON on one line (or base64-encoded).
GOOGLE_SERVICE_ACCOUNT_KEY=""
GOOGLE_CALENDAR_ID=""
